# Applications Settings
ECRS_DEBUG=True
ECRS_ENVIRONMENT=development
ECRS_SECRET_KEY=your-secret-key-change-in-production

# Server
ECRS_HOST=0.0.0.0
ECRS_PORT=8000

# Database
# Default: SQLite (works without installing PostgreSQL)
ECRS_DATABASE_URL=sqlite:///./ecommerce_recommendations.db

# Alternative (root-level DB file):
# ECRS_DATABASE_URL=sqlite:///../database/ecommerce_recommendations.db
# Example Postgres:
# ECRS_DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce_recommendations

# Redis
ECRS_REDIS_URL=redis://localhost:6379/0

# CORS
ECRS_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# JWT
ECRS_ACCESS_TOKEN_EXPIRE_MINUTES=30
ECRS_REFRESH_TOKEN_EXPIRE_DAYS=7

# ML Models
ECRS_MODEL_PATH=./ml/models
ECRS_BATCH_SIZE=32
ECRS_EMBEDDING_DIM=50
